{% extends 'base.html.twig' %}

{% block title %}{{ parent() }} Multiples étiquettes{% endblock %}

{% block body %}

    <div class="container-fluid">
        <div class="card bg-light-info shadow-none position-relative overflow-hidden">
            <div class="card-body px-4 py-3">
                <div class="row align-items-center">
                    <div class="col-9">
                        <h4 class="fw-semibold mb-8">Multiples étiquettes</h4>
                        <nav aria-label="breadcrumb">
                            <ol class="breadcrumb">
                                <li class="breadcrumb-item"><a class="text-muted" href="#">Etat</a></li>
                                <li class="breadcrumb-item"><a class="text-muted" href="#">Etiquette</a></li>
                                <li class="breadcrumb-item" aria-current="page">Multiple</li>
                            </ol>
                        </nav>
                    </div>
                    <div class="col-3">
                        <div class="text-center mb-n5">
                            <span class="head-icon"><i class="ti-package"></i></span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <section>
            <div class="row">
                <div class="col-12">
                    <div class="card">
                        <div class="card-header">
                            <div class="row align-items-center">
                                <div class="col"><h5 class="mb-2 fw-semibold fs-4">Liste</h5></div>
                                <div class="col-auto d-flex gap-2">
                                    <button id="btn-voir-selection"
                                            class="btn btn-outline-secondary"
                                            disabled
                                            title="Épingler les produits sélectionnés en haut du tableau">
                                        <i class="ti-eye me-1"></i>
                                        Voir la sélection
                                        (<span id="selection-count-voir">0</span>)
                                    </button>
                                    <button id="btn-imprimer-selection"
                                            class="btn btn-primary"
                                            disabled>
                                        <i class="ti-printer me-1"></i>
                                        Imprimer la sélection
                                        (<span id="selection-count">0</span>)
                                    </button>
                                </div>
                            </div>
                        </div>
                        <div class="card-body">
                            {# --- Bandeau sélection épinglée --- #}
                            <div id="selection-panel" class="d-none mb-3">
                                <div class="d-flex align-items-center justify-content-between mb-2">
                                    <span class="fw-semibold text-primary">
                                        <i class="ti-pin me-1"></i>
                                        Produits sélectionnés (<span id="panel-count">0</span>)
                                    </span>
                                    <button id="btn-deselect-all" class="btn btn-sm btn-outline-danger">
                                        <i class="ti-close me-1"></i> Tout désélectionner
                                    </button>
                                </div>
                                <div class="table-responsive">
                                    <table id="table-selection" class="table table-sm table-bordered table-hover mb-0" style="width:100%">
                                        <thead class="table-primary">
                                            <tr>
                                                <th style="width:40px"></th>
                                                <th>Référence</th>
                                                <th>Code Barre</th>
                                                <th>Libellé</th>
                                                <th>Prix Achat</th>
                                                <th>Prix Vente</th>
                                                <th>Stock</th>
                                                <th>Catégorie</th>
                                            </tr>
                                        </thead>
                                        <tbody id="selection-tbody">
                                        </tbody>
                                    </table>
                                </div>
                                <hr class="mt-3 mb-0">
                            </div>
                            {# --- Fin bandeau sélection --- #}
                            <div id="table-loader" class="table-loader">
                                <div class="loader"></div>
                            </div>
                            <div class="table-responsive">
                                <table id="liste-produits" class="table table-striped table-bordered" style="width:100%">
                                    <thead>
                                    <tr>
                                        <th><input type="checkbox" id="select-all" title="Tout sélectionner" /></th>
                                        <th>Référence</th>
                                        <th>Code Barre</th>
                                        <th>Libellé</th>
                                        <th>Prix Achat</th>
                                        <th>Prix Vente</th>
                                        <th>Stock</th>
                                        <th>Catégorie</th>
                                        <th>Actions</th>
                                    </tr>
                                    </thead>
                                    <tbody>
                                    </tbody>
                                </table>
                            </div>

                        </div>
                    </div>
                </div>
            </div>
        </section>



    </div>

{% endblock %}
{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('assets/vendor/css/prism.min.css') }}">
    <link rel="stylesheet" href="{{ asset('assets/vendor/DataTables/datatables.min.css') }}">
    <link rel="stylesheet" href="{{ absolute_url(asset('assets/vendor/css/select2.min.css')) }}">
{% endblock %}
{% block javascripts %}
    {{ parent() }}
    <script src="{{ asset('assets/vendor/js/prism.js') }}"></script>
    <script src="{{ asset('assets/vendor/DataTables/datatables.min.js') }}"></script>
    <script src="{{ absolute_url(asset('assets/vendor/js/select2.full.min.js')) }}"></script>
    <script src="{{ absolute_url(asset('assets/vendor/js/select2.min.js')) }}"></script>

    <style>
        #selection-panel {
            background: #f0f4ff;
            border: 1px solid #c7d6f7;
            border-radius: 8px;
            padding: 14px 16px;
        }
        #btn-voir-selection.actif {
            background-color: #4361ee;
            color: #fff;
            border-color: #4361ee;
        }
        #table-selection tbody tr:hover td {
            background-color: #e8eeff !important;
        }
        #table-selection tbody tr td:first-child {
            text-align: center;
            vertical-align: middle;
        }
    </style>

    <script>
        $(document).ready(function() {

            // ---------------------------------------------------------
            // Cache des données complètes de chaque ligne sélectionnée
            // clé : id (string), valeur : objet rowData
            // ---------------------------------------------------------
            const selectedIds   = new Set();
            const selectedData  = new Map();
            let   voirActif     = false;

            // ---------------------------------------------------------
            // Initialisation DataTable
            // ---------------------------------------------------------
            const table = $('#liste-produits').DataTable({
                "processing": true,
                "serverSide": true,
                "ajax": "{{ path('api_produits_datatables_choix') }}",
                "columns": [
                    { "data": "checkbox",  "orderable": false, "searchable": false, "width": "40px", "className": "text-center" },
                    { "data": "reference" },
                    { "data": "codebarre" },
                    { "data": "libelle" },
                    { "data": "prixAchat" },
                    { "data": "prixVente" },
                    { "data": "stock" },
                    { "data": "categorie" },
                    { "data": "actions", "orderable": false }
                ],
                "language": {
                    "url": "//cdn.datatables.net/plug-ins/1.13.6/i18n/fr-FR.json"
                }
            });

            // ---------------------------------------------------------
            // Mise à jour globale des compteurs + boutons
            // ---------------------------------------------------------
            function updateUI() {
                const count = selectedIds.size;
                $('#selection-count').text(count);
                $('#selection-count-voir').text(count);
                $('#panel-count').text(count);
                $('#btn-imprimer-selection').prop('disabled', count === 0);
                $('#btn-voir-selection').prop('disabled', count === 0);

                // Si le panneau est ouvert, on le rafraîchit
                if (voirActif) renderSelectionPanel();

                // Si on désélectionne tout alors que le panneau est ouvert → on le ferme
                if (count === 0 && voirActif) toggleVoirSelection(false);
            }

            // ---------------------------------------------------------
            // Rendu du panneau de sélection épinglé
            // ---------------------------------------------------------
            function renderSelectionPanel() {
                const tbody = $('#selection-tbody').empty();
                selectedData.forEach(function(d, id) {
                    const tr = $('<tr>').append(
                        $('<td>').html(
                            '<button class="btn btn-sm btn-link text-danger p-0 btn-deselect-one" data-id="' + id + '" title="Retirer"><i class="ti-close"></i></button>'
                        ),
                        $('<td>').text(d.reference  ?? ''),
                        $('<td>').text(d.codebarre  ?? ''),
                        $('<td>').text(d.libelle    ?? ''),
                        $('<td>').text(d.prixAchat  ?? ''),
                        $('<td>').text(d.prixVente  ?? ''),
                        $('<td>').text(d.stock      ?? ''),
                        $('<td>').text(d.categorie  ?? '')
                    );
                    tbody.append(tr);
                });
            }

            function toggleVoirSelection(forceState) {
                voirActif = (forceState !== undefined) ? forceState : !voirActif;
                if (voirActif) {
                    renderSelectionPanel();
                    $('#selection-panel').removeClass('d-none');
                    $('#btn-voir-selection').addClass('actif').html('<i class="ti-eye-slash me-1"></i> Masquer la sélection (<span id="selection-count-voir">' + selectedIds.size + '</span>)');
                } else {
                    $('#selection-panel').addClass('d-none');
                    $('#btn-voir-selection').removeClass('actif').html('<i class="ti-eye me-1"></i> Voir la sélection (<span id="selection-count-voir">' + selectedIds.size + '</span>)');
                }
            }

            // ---------------------------------------------------------
            // Checkbox individuelle
            // ---------------------------------------------------------
            $('#liste-produits tbody').on('change', '.produit-checkbox', function () {
                const id       = $(this).val();
                const rowData  = table.row($(this).closest('tr')).data();
                if ($(this).is(':checked')) {
                    selectedIds.add(id);
                    if (rowData) selectedData.set(id, rowData);
                } else {
                    selectedIds.delete(id);
                    selectedData.delete(id);
                    $('#select-all').prop('checked', false);
                }
                updateUI();
            });

            // ---------------------------------------------------------
            // Tout sélectionner (page courante)
            // ---------------------------------------------------------
            $('#select-all').on('change', function () {
                const checked = $(this).is(':checked');
                $('#liste-produits tbody .produit-checkbox').each(function () {
                    $(this).prop('checked', checked);
                    const id      = $(this).val();
                    const rowData = table.row($(this).closest('tr')).data();
                    if (checked) {
                        selectedIds.add(id);
                        if (rowData) selectedData.set(id, rowData);
                    } else {
                        selectedIds.delete(id);
                        selectedData.delete(id);
                    }
                });
                updateUI();
            });

            // ---------------------------------------------------------
            // Resync checkboxes après chaque draw DataTables
            // ---------------------------------------------------------
            table.on('draw', function () {
                $('#select-all').prop('checked', false);
                $('#liste-produits tbody .produit-checkbox').each(function () {
                    const id = $(this).val();
                    if (selectedIds.has(id)) {
                        $(this).prop('checked', true);
                        // Enrichit le cache si la ligne repasse sous notre curseur
                        const rowData = table.row($(this).closest('tr')).data();
                        if (rowData && !selectedData.has(id)) selectedData.set(id, rowData);
                    }
                });
            });

            // ---------------------------------------------------------
            // Bouton "Voir la sélection"
            // ---------------------------------------------------------
            $('#btn-voir-selection').on('click', function () {
                if (selectedIds.size === 0) return;
                toggleVoirSelection();
            });

            // ---------------------------------------------------------
            // Retirer un produit depuis le panneau
            // ---------------------------------------------------------
            $('#selection-tbody').on('click', '.btn-deselect-one', function () {
                const id = $(this).data('id').toString();
                selectedIds.delete(id);
                selectedData.delete(id);
                // Décoche dans le tableau principal si la ligne est visible
                $('#liste-produits tbody .produit-checkbox[value="' + id + '"]').prop('checked', false);
                $('#select-all').prop('checked', false);
                updateUI();
            });

            // ---------------------------------------------------------
            // Tout désélectionner depuis le panneau
            // ---------------------------------------------------------
            $('#btn-deselect-all').on('click', function () {
                selectedIds.clear();
                selectedData.clear();
                $('#liste-produits tbody .produit-checkbox').prop('checked', false);
                $('#select-all').prop('checked', false);
                updateUI();
                toggleVoirSelection(false);
            });

            // ---------------------------------------------------------
            // Bouton impression multiple
            // ---------------------------------------------------------
            $('#btn-imprimer-selection').on('click', function () {
                if (selectedIds.size === 0) return;
                const ids = Array.from(selectedIds).join(',');
                window.open('{{ path('app_main_etiquette_multiple') }}?ids=' + ids, '_blank');
            });
        });
    </script>

    <script>
        $(".select2").select2();
    </script>
{% endblock %}
