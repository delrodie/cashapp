<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Étiquette produit-{{ produit.reference }}</title>
    <!-- JsBarcode pour la génération du code-barres -->
    <script src="https://cdn.jsdelivr.net/npm/jsbarcode@3.11.5/dist/JsBarcode.all.min.js"></script>
    <style>
        /* Définition de la page d'impression exacte */
        @page {
            size: 58mm 40mm;
            margin: 0;
        }

        /* Styles généraux pour l'aperçu à l'écran */
        body {
            font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
            background-color: #e0e0e0;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
            margin: 0;
            padding: 0;
        }

        /* Bouton d'impression (masqué lors de l'impression) */
        .no-print {
            margin-bottom: 20px;
        }

        button {
            padding: 10px 20px;
            font-size: 16px;
            font-weight: bold;
            color: white;
            background-color: #007bff;
            border: none;
            border-radius: 5px;
            cursor: pointer;
            box-shadow: 0 4px 6px rgba(0,0,0,0.1);
            transition: background-color 0.3s;
        }

        button:hover {
            background-color: #0056b3;
        }

        /* * CONTENEUR DE L'ÉTIQUETTE
         * Dimensions strictes 58x40mm
         */
        .etiquette {
            width: 58mm;
            height: 40mm;
            background-color: white;
            box-sizing: border-box;
            position: relative;
            overflow: hidden;
            /* Une légère ombre pour bien la voir à l'écran */
            box-shadow: 0 0 10px rgba(0,0,0,0.2);
            padding: 2mm;
            color: black;
        }

        /* Séparateur horizontal (La ligne grise fine) */
        .divider {
            position: absolute;
            top: 8mm;
            left: 0;
            width: 100%;
            height: 1px;
            background-color: #e5e5e5;
        }

        /* --- POSITIONNEMENT DES ÉLÉMENTS --- */

        .titre {
            position: absolute;
            top: 2.5mm;
            left: 1.5mm;
            width: 100%;
            text-align: center;
            font-size: 9.0pt;
            font-weight: 500;
            letter-spacing: 0.2px;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .devise {
            position: absolute;
            top: 9mm;
            right: 2mm;
            font-size: 9pt;
            font-weight: 600;
        }

        .prix {
            position: absolute;
            top: 11.5mm;
            right: 2mm;
            font-size: 32pt;
            font-weight: 900;
            letter-spacing: -1.5px;
            line-height: 1;
        }

        .code-interne {
            position: absolute;
            top: 24mm;
            left: 2mm;
            font-size: 8.5pt;
            font-weight: bold;
        }

        .barcode-container {
            position: absolute;
            bottom: -0.5mm;
            left: 1.5mm;
        }

        .categorie {
            position: absolute;
            bottom: 2mm;
            right: 2mm;
            font-size: 7pt;
            font-weight: bold;
            letter-spacing: 0.5px;
        }

        /* * STYLES SPÉCIFIQUES POUR L'IMPRESSION
         */
        @media print {
            body {
                background-color: white;
                display: block; /* Supprime le flexbox pour l'impression */
            }
            .no-print {
                display: none !important; /* Masque le bouton */
            }
            .etiquette {
                box-shadow: none; /* Retire l'ombre */
                margin: 0;
                padding: 2mm;
                page-break-after: avoid;
            }
        }
    </style>
</head>
<body>



<!-- Modèle d'étiquette -->
<div class="etiquette">
    <div class="titre">{{ produit.libelle }}</div>

    <div class="divider"></div>

    <div class="devise">FCFA</div>
    <div class="prix">{{ produit.prixVente|number_format(0,'','.') }}</div>

    <div class="code-interne">{{ produit.reference }}</div>

    <div class="barcode-container">
        <!-- Le code barres sera généré ici en SVG -->
        <svg id="barcode"></svg>
    </div>

    <div class="categorie">{{ produit.categorie.libelle }}</div>
</div>

<!-- Zone UI masquée à l'impression -->
<div class="no-print" style="margin-top: 50px; text-align: center;">
    <button onclick="window.print()">🖨️ Imprimer l'étiquette</button>

</div>

<script>
    window.print();
</script>
</body>
</html>