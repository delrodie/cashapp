{% extends 'base.html.twig' %}

{% block title %}{{ parent() }} Gestion liste des produits{% endblock %}

{% block body %}

    <div class="container-fluid">
        <div class="card bg-light-info shadow-none position-relative overflow-hidden">
            <div class="card-body px-4 py-3">
                <div class="row align-items-center">
                    <div class="col-9">
                        <h4 class="fw-semibold mb-8">Gestion des produits</h4>
                        <nav aria-label="breadcrumb">
                            <ol class="breadcrumb">
                                <li class="breadcrumb-item"><a class="text-muted" href="#">Modules</a></li>
                                <li class="breadcrumb-item"><a class="text-muted" href="#">Produits</a></li>
                                <li class="breadcrumb-item" aria-current="page">produits</li>
                            </ol>
                        </nav>
                    </div>
                    <div class="col-3">
                        <div class="text-center mb-n5">
                            <span class="head-icon"><i class="ti-package"></i></span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <section>
            <div class="row">
                <div class="col-12">
                    <div class="card">
                        <div class="card-header">
                            <div class="row">
                                <div class="col"><h5 class="mb-2 fw-semibold fs-4">Liste</h5></div>
{#                                <div class="col">#}
{#                                    <div class="action">#}
{#                                        <button class="btn btn-primary" data-bs-toggle="modal"#}
{#                                                data-bs-target="#primary-header-modal"><i class="ti-plus"></i> Ajouter</button>#}
{#                                    </div>#}
{#                                </div>#}
                            </div>

                        </div>
                        <div class="card-body">
                            <div id="table-loader" class="table-loader">
                                <div class="loader"></div>
                            </div>
                            <div class="table-responsive">
                                <table id="liste-produits" class="table table-striped table-bordered" style="width:100%">
                                    <thead>
                                    <tr>
                                        <th>Référence</th>
                                        <th>Code Barre</th>
                                        <th>Libellé</th>
                                        <th>Prix Achat</th>
                                        <th>Prix Vente</th>
                                        <th>Stock</th>
                                        <th>Catégorie</th>
                                        <th>Actions</th>
                                    </tr>
                                    </thead>
                                    <tbody>
                                    </tbody>
                                </table>
                            </div>

                        </div>
                    </div>
                </div>
            </div>
        </section>



    </div>

{% endblock %}
{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('assets/vendor/css/prism.min.css') }}">
    <link rel="stylesheet" href="{{ asset('assets/vendor/DataTables/datatables.min.css') }}">
    <link rel="stylesheet" href="{{ absolute_url(asset('assets/vendor/css/select2.min.css')) }}">
{% endblock %}
{% block javascripts %}
    {{ parent() }}
    <script src="{{ asset('assets/vendor/js/prism.js') }}"></script>
    <script src="{{ asset('assets/vendor/DataTables/datatables.min.js') }}"></script>
    <script src="{{ absolute_url(asset('assets/vendor/js/select2.full.min.js')) }}"></script>
    <script src="{{ absolute_url(asset('assets/vendor/js/select2.min.js')) }}"></script>

    <script>
        $(document).ready(function() {
            $('#liste-produits').DataTable({
                "processing": true,
                "serverSide": true, // Activation du mode serveur !
                "ajax": "{{ path('api_produits_datatables') }}", // Appel de notre route Symfony
                "columns": [
                    { "data": "reference" },
                    { "data": "codebarre" },
                    { "data": "libelle" },
                    { "data": "prixAchat" },
                    { "data": "prixVente" },
                    { "data": "stock" },
                    { "data": "categorie" },
                    { "data": "actions", "orderable": false } // Pas de tri sur les boutons
                ],
                "language": {
                    "url": "//cdn.datatables.net/plug-ins/1.13.6/i18n/fr-FR.json" // Traduction française
                }
            });
        });
    </script>

    <script>
        $(".select2").select2();
    </script>
{% endblock %}
